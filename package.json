{
  "name": "cyrene-agent-replica-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/app/main.js",
  "description": "Learning-oriented Cyrene-Agent replica lab",
  "scripts": {
    "build": "npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "dev:chat": "tsx src/cli/chat.ts",
    "dev:electron": "npm run build && electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^43.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  }
}
